# WatermarkForge 环境变量模板
# 复制此文件为 .env 并填入实际值

# DeepSeek API 密钥（OpenAI 兼容格式）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 水印加密主密钥（首次运行时自动生成，也可手动指定）
# 留空则由 key_manager 自动生成并保存到 keys/ 目录
WATERMARK_MASTER_KEY=

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 审计日志存放路径
AUDIT_LOG_PATH=logs/audit.log
